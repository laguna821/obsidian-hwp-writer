{
  "name": "obsidian-hwp-writer",
  "version": "1.6.0",
  "description": "Obsidian HWP Writer with legacy HWP flow and DOCX v2 export/preview pipeline",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "verify:portable": "node scripts/verify-portable.mjs"
  },
  "keywords": [
    "obsidian",
    "hwp",
    "hwpx",
    "docx",
    "markdown",
    "word"
  ],
  "license": "MIT",
  "dependencies": {
    "@xmldom/xmldom": "^0.8.10",
    "docx-preview": "^0.3.6",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^4.10.38",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.1",
    "obsidian": "latest",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
